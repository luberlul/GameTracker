{
  "name": "gametrack",
  "version": "1.0.0",
  "private": true,
  "description": "Premium gaming tracker — Next.js + Electron desktop app.",
  "author": {
    "name": "João Player",
    "email": "l.lucasbernardino@gmail.com"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "next:dev": "next dev",
    "next:build": "next build",
    "next:export": "cross-env BUILD_TARGET=electron next build",
    "next:start": "next start",
    "electron:build": "tsc -p electron/tsconfig.json",
    "electron:dev": "wait-on tcp:3000 && cross-env NODE_ENV=development electron .",
    "dev": "npm run electron:build && concurrently -k -n NEXT,ELEC -c blue,magenta \"npm:next:dev\" \"npm:electron:dev\"",
    "build": "npm run next:export && npm run electron:build",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:portable": "npm run build && electron-builder --win portable",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "1.1.2",
    "@tanstack/react-query": "5.62.11",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "11.18.2",
    "howlongtobeat": "^1.8.0",
    "lucide-react": "0.487.0",
    "next": "^16.2.6",
    "next-themes": "0.4.6",
    "prisma": "^7.8.0",
    "react": "19.0.0",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "19.0.0",
    "recharts": "2.15.2",
    "tailwind-merge": "3.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.1.12",
    "@types/node": "22.10.7",
    "@types/react": "19.0.7",
    "@types/react-dom": "19.0.3",
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "4.1.12",
    "typescript": "5.7.3",
    "wait-on": "8.0.2"
  },
  "build": {
    "appId": "com.gametrack.app",
    "productName": "GameTrack",
    "copyright": "Copyright © 2026 João Player",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "GameTrack-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GameTrack",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "GameTrack-${version}-portable.${ext}"
    },
    "publish": null
  },
  "overrides": {
    "postcss": "^8.5.10",
    "axios": "^1.8.4",
    "@hono/node-server": "^1.19.13"
  }
}
